<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Voice Modulator Demo</title>
    <style>
        body {
            font-family: sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100vh;
            background-color: #121212;
            color: #ffffff;
            margin: 0;
        }
        button {
            padding: 15px 30px;
            font-size: 1.2rem;
            margin: 10px;
            border-radius: 8px;
            border: none;
            cursor: pointer;
            font-weight: bold;
        }
        #startBtn { background-color: #4CAF50; color: white; }
        #stopBtn { background-color: #f44336; color: white; display: none; }
        .controls { margin-top: 20px; text-align: center; }
        input[type="range"] { width: 80vw; max-width: 300px; }
    </style>
</head>
<body>

    <h2>Scammer Voice Demo</h2>
    <p>Demonstrating real-time audio manipulation.</p>

    <button id="startBtn">Start Microphone</button>
    <button id="stopBtn">Stop Microphone</button>

    <div class="controls">
        <label for="freqControl">Modulation Frequency: <span id="freqValue">50</span> Hz</label><br>
        <input type="range" id="freqControl" min="10" max="1000" value="50">
        <p style="font-size: 0.8rem; color: #aaa;">Slide up for higher pitch/more metallic artifacts.</p>
    </div>

    <script>
        let audioContext;
        let mediaStream;
        let sourceNode;
        let oscillator;
        let ringModNode;

        const startBtn = document.getElementById('startBtn');
        const stopBtn = document.getElementById('stopBtn');
        const freqControl = document.getElementById('freqControl');
        const freqValue = document.getElementById('freqValue');

        // Update display value
        freqControl.addEventListener('input', (e) => {
            freqValue.textContent = e.target.value;
            if (oscillator) {
                oscillator.frequency.value = e.target.value;
            }
        });

        startBtn.addEventListener('click', async () => {
            try {
                // Cell phone browsers require HTTPS or localhost to access the microphone
                mediaStream = await navigator.mediaDevices.getUserMedia({ audio: true });
                
                audioContext = new (window.AudioContext || window.webkitAudioContext)();
                
                // 1. Get the raw microphone input
                sourceNode = audioContext.createMediaStreamSource(mediaStream);

                // 2. Create the Ring Modulator (Gain Node)
                // We use a gain node, but instead of a constant volume, we drive the volume
                // up and down incredibly fast using an oscillator.
                ringModNode = audioContext.createGain();
                ringModNode.gain.value = 0; // Base volume at 0, oscillator does the work

                // 3. Create the Oscillator (The "Robot/Metallic" effect generator)
                oscillator = audioContext.createOscillator();
                oscillator.type = 'sine';
                oscillator.frequency.value = freqControl.value;

                // Connect the oscillator to the gain parameter of the ring modulator
                oscillator.connect(ringModNode.gain);

                // 4. Route the audio: Mic -> Ring Modulator -> Speaker
                sourceNode.connect(ringModNode);
                ringModNode.connect(audioContext.destination);

                // Start the modulation
                oscillator.start();

                startBtn.style.display = 'none';
                stopBtn.style.display = 'inline-block';

            } catch (err) {
                alert('Microphone access denied or not supported: ' + err.message);
            }
        });

        stopBtn.addEventListener('click', () => {
            if (audioContext) {
                audioContext.close();
            }
            if (mediaStream) {
                mediaStream.getTracks().forEach(track => track.stop());
            }
            startBtn.style.display = 'inline-block';
            stopBtn.style.display = 'none';
        });
    </script>
</body>
</html>
